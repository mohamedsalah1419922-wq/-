<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="مطعم بيت الأسماك، وجهتك الأولى لتجربة أشهى المأكولات البحرية الطازجة بأجواء فاخرة.">
    <title>مطعم بيت الأسماك | فن المذاق البحري الأصيل</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.0/css/all.min.css">

    <style>
        /* CSS Variables for Easy Theming */
        :root {
            --dark-bg: #12151a; /* لون الخلفية الداكن */
            --primary-accent: #00bcd4; /* اللون السماوي/السيان */
            --secondary-bg: #1a1e25; /* لون أغمق قليلاً للخلفيات الثانوية */
            --text-color: #e0e0e0; /* لون النص الأساسي */
            --heading-color: #ffffff; /* لون العناوين */
            --font-heading: 'Playfair Display', serif;
            --font-body: 'Montserrat', sans-serif;
        }

        /* Global Styles */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-body);
            background-color: var(--dark-bg);
            color: var(--text-color);
            line-height: 1.6;
        }

        .container {
            max-width: 1200px;
            margin: auto;
            padding: 0 20px;
        }

        h1, h2, h3 {
            font-family: var(--font-heading);
            color: var(--heading-color);
            margin-bottom: 20px;
        }
        
        h2 {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 40px;
            position: relative;
        }

        h2::after {
            content: '';
            display: block;
            width: 80px;
            height: 3px;
            background-color: var(--primary-accent);
            margin: 10px auto 0;
        }

        section {
            padding: 80px 0;
        }

        .btn {
            display: inline-block;
            background-color: var(--primary-accent);
            color: var(--dark-bg);
            padding: 12px 25px;
            border-radius: 5px;
            text-decoration: none;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0, 188, 212, 0.3);
        }

        /* Header & Navigation */
        .main-header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            background-color: rgba(18, 21, 26, 0.9);
            backdrop-filter: blur(10px);
            z-index: 1000;
            padding: 15px 0;
            border-bottom: 1px solid var(--secondary-bg);
        }

        .main-header .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-family: var(--font-heading);
            font-size: 1.8rem;
            color: var(--heading-color);
            text-decoration: none;
        }
        
        .logo i {
            color: var(--primary-accent);
        }

        .nav-links {
            list-style: none;
            display: flex;
        }

        .nav-links li {
            margin-right: 30px;
        }

        .nav-links a {
            color: var(--text-color);
            text-decoration: none;
            font-weight: bold;
            transition: color 0.3s ease;
        }

        .nav-links a:hover {
            color: var(--primary-accent);
        }

        .hamburger {
            display: none;
            cursor: pointer;
            font-size: 1.5rem;
        }

        /* Hero Section */
        #hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: white;
            background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1565599243219-75214a1c6a23?q=80&w=1974&auto=format&fit=crop') no-repeat center center/cover;
            /* ملاحظة: يجب استبدال الصورة بأخرى احترافية خاصة بالمطعم */
        }
        
        .hero-content h1 {
            font-size: 4rem;
            margin-bottom: 20px;
        }

        .hero-content p {
            font-size: 1.2rem;
            margin-bottom: 30px;
        }

        /* About Section */
        #about .container {
            display: flex;
            align-items: center;
            gap: 50px;
        }
        
        #about .about-content {
            flex: 1;
        }

        #about .about-image {
            flex: 1;
        }

        #about img {
            max-width: 100%;
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        
        /* Featured Dishes Section */
        #featured-dishes {
            background-color: var(--secondary-bg);
        }

        .dishes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
        }

        .dish-card {
            background-color: var(--dark-bg);
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            transition: transform 0.3s ease;
        }
        
        .dish-card:hover {
            transform: translateY(-10px);
        }

        .dish-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }
        
        .dish-card-content {
            padding: 20px;
        }

        .dish-card h3 {
            margin-bottom: 10px;
        }

        .dish-price {
            color: var(--primary-accent);
            font-weight: bold;
            font-size: 1.2rem;
        }

        /* Menu Section */
        .menu-tabs {
            text-align: center;
            margin-bottom: 40px;
        }

        .menu-tab {
            background: none;
            border: 2px solid var(--secondary-bg);
            color: var(--text-color);
            padding: 10px 20px;
            margin: 0 5px;
            border-radius: 5px;
            cursor: pointer;
            font-family: var(--font-body);
            font-size: 1rem;
            transition: all 0.3s ease;
        }
        
        .menu-tab.active, .menu-tab:hover {
            background-color: var(--primary-accent);
            color: var(--dark-bg);
            border-color: var(--primary-accent);
        }

        .menu-content {
            display: none;
        }
        
        .menu-content.active {
            display: block;
        }

        /* Testimonials Section */
        #testimonials {
             background-color: var(--secondary-bg);
        }
        .testimonial-card {
            background: var(--dark-bg);
            padding: 30px;
            border-radius: 10px;
            max-width: 700px;
            margin: auto;
            text-align: center;
        }

        .testimonial-card p {
            font-style: italic;
            margin-bottom: 20px;
            font-size: 1.1rem;
        }
        
        .testimonial-author {
            font-weight: bold;
            color: var(--primary-accent);
        }

        /* Contact Section */
        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
            align-items: center;
        }

        .contact-info-item {
            display: flex;
            align-items: center;
            margin-bottom: 25px;
        }

        .contact-info-item i {
            color: var(--primary-accent);
            font-size: 1.5rem;
            margin-left: 20px;
            width: 30px;
        }
        
        .contact-info-item p {
            margin: 0;
            font-size: 1.1rem;
        }
        
        .contact-info-item a {
            color: var(--text-color);
            text-decoration: none;
            font-size: 1.1rem;
        }

        .map-container {
            border-radius: 10px;
            overflow: hidden;
            height: 400px;
        }

        /* Footer */
        footer {
            background-color: var(--secondary-bg);
            text-align: center;
            padding: 40px 0;
        }
        
        .social-links a {
            color: var(--text-color);
            font-size: 1.5rem;
            margin: 0 15px;
            transition: color 0.3s ease;
        }

        .social-links a:hover {
            color: var(--primary-accent);
        }
        
        footer p {
            margin-top: 20px;
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            h1 { font-size: 2.8rem; }
            h2 { font-size: 2rem; }
            .nav-links {
                display: none;
                flex-direction: column;
                position: absolute;
                top: 70px;
                right: 0;
                background-color: var(--dark-bg);
                width: 100%;
                text-align: center;
                padding: 20px 0;
            }
            .nav-links.active {
                display: flex;
            }
            .nav-links li {
                margin: 15px 0;
            }
            .hamburger {
                display: block;
            }
            #about .container, .contact-grid {
                flex-direction: column;
                grid-template-columns: 1fr;
            }
            .about-image {
                margin-top: 30px;
            }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header class="main-header">
        <div class="container">
            <a href="#hero" class="logo"><i class="fas fa-fish"></i> بيت الأسماك</a>
            <nav>
                <ul class="nav-links">
                    <li><a href="#hero">الرئيسية</a></li>
                    <li><a href="#about">عن المطعم</a></li>
                    <li><a href="#menu">قائمة الطعام</a></li>
                    <li><a href="#contact">تواصل معنا</a></li>
                </ul>
            </nav>
            <div class="hamburger">
                <i class="fas fa-bars"></i>
            </div>
        </div>
    </header>

    <main>
        <!-- Hero Section -->
        <section id="hero">
            <div class="hero-content">
                <h1>فن المذاق البحري الأصيل</h1>
                <p>حيث تلتقي النكهات الطازجة بالفخامة</p>
                <a href="#menu" class="btn">اكتشف القائمة</a>
            </div>
        </section>

        <!-- About Section -->
        <section id="about">
            <div class="container">
                <div class="about-content">
                    <h2>قصتنا</h2>
                    <p>في "بيت الأسماك"، نحن لا نقدم طعامًا فحسب، بل نقدم تجربة. بدأت رحلتنا بشغف بسيط: مشاركة أشهى كنوز البحر المحضرة بإتقان. نؤمن بأن الجودة تبدأ من المصدر، لذلك نختار مكوناتنا بعناية فائقة لنضمن لكم مذاقًا لا يُنسى في كل طبق.</p>
                    <br>
                    <p>مهمتنا هي أن نكون وجهتكم الأولى عندما تفكرون في المأكولات البحرية، حيث تجتمع الأجواء الراقية، الخدمة الممتازة، والنكهات الأصيلة.</p>
                </div>
                <div class="about-image">
                     <!-- ملاحظة: استبدل الصورة بصورة لديكور المطعم الداخلي -->
                    <img src="https://images.unsplash.com/photo-1552566626-52f8b828add9?q=80&w=2070&auto=format&fit=crop" alt="ديكور مطعم بيت الأسماك">
                </div>
            </div>
        </section>

        <!-- Featured Dishes Section -->
        <section id="featured-dishes">
            <div class="container">
                <h2>أطباقنا المميزة</h2>
                <div class="dishes-grid">
                    <!-- طبق 1 -->
                    <div class="dish-card">
                        <img src="https://images.unsplash.com/photo-1625944230154-2133745a55ac?q=80&w=1974&auto=format&fit=crop" alt="طبق بحري">
                        <div class="dish-card-content">
                            <h3>طاجن سي فود بالكريمة</h3>
                            <p>مزيج غني من الجمبري، الكاليماري، وبلح البحر في صلصة كريمة شهية.</p>
                            <p class="dish-price">120 جنيه</p>
                        </div>
                    </div>
                    <!-- طبق 2 -->
                    <div class="dish-card">
                        <img src="https://images.unsplash.com/photo-1598421833134-1061c56a5996?q=80&w=1935&auto=format&fit=crop" alt="سمك مشوي">
                        <div class="dish-card-content">
                            <h3>سمك دنيس مشوي</h3>
                            <p>سمك دنيس طازج متبل بأعشابنا الخاصة ومشوي على الفحم.</p>
                            <p class="dish-price">حسب الوزن</p>
                        </div>
                    </div>
                    <!-- طبق 3 -->
                    <div class="dish-card">
                        <img src="https://images.unsplash.com/photo-1604329221533-36f6d8a3f85e?q=80&w=1964&auto=format&fit=crop" alt="طبق جمبري">
                        <div class="dish-card-content">
                            <h3>جمبري بتر فلاي</h3>
                            <p>جمبري جامبو مشوي مع خلطة الثوم والليمون والزبدة.</p>
                            <p class="dish-price">150 جنيه</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        
        <!-- Menu Section -->
        <section id="menu">
            <div class="container">
                <h2>قائمة الطعام الكاملة</h2>
                <div class="menu-tabs">
                    <button class="menu-tab active" data-target="seafood">المأكولات البحرية</button>
                    <button class="menu-tab" data-target="fish">الأسماك الطازجة</button>
                    <button class="menu-tab" data-target="drinks">المشروبات</button>
                </div>
                
                <!-- Seafood Content -->
                <div id="seafood" class="menu-content active">
                    <div class="dishes-grid">
                        <!-- أضف أطباق المأكولات البحرية هنا -->
                        <div class="dish-card">...</div>
                        <div class="dish-card">...</div>
                    </div>
                </div>

                <!-- Fresh Fish Content -->
                <div id="fish" class="menu-content">
                    <div class="dishes-grid">
                        <!-- أضف أنواع الأسماك هنا -->
                        <div class="dish-card">...</div>
                    </div>
                </div>
                
                <!-- Drinks Content -->
                <div id="drinks" class="menu-content">
                    <div class="dishes-grid">
                        <!-- أضف المشروبات هنا -->
                         <div class="dish-card">...</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Testimonials Section -->
        <section id="testimonials">
            <div class="container">
                <h2>ماذا يقول عملاؤنا</h2>
                <div class="testimonial-card">
                    <p>"بكل أمانة، أفضل مطعم مأكولات بحرية جربته في حياتي. الطعم طازج والخدمة أكثر من رائعة. طاجن السي فود لا يُعلى عليه!"</p>
                    <p class="testimonial-author">- أحمد خالد</p>
                </div>
            </div>
        </section>
        
        <!-- Contact Section -->
        <section id="contact">
            <div class="container">
                <h2>تواصل معنا واحجز طاولتك</h2>
                <div class="contact-grid">
                    <div class="contact-info">
                        <h3>معلومات الاتصال</h3>
                        <div class="contact-info-item">
                            <i class="fas fa-phone"></i>
                            <p><a href="tel:+201234567890">0123 456 7890</a></p>
                        </div>
                        <div class="contact-info-item">
                            <i class="fas fa-map-marker-alt"></i>
                            <p>123 شارع البحر، حي الأناقة، مدينة المذاق</p>
                        </div>
                        <div class="contact-info-item">
                            <i class="fas fa-clock"></i>
                            <p>مواعيد العمل: يوميًا من 12:00 ظهرًا حتى 12:00 صباحًا</p>
                        </div>
                    </div>
                    <div class="map-container">
                        <!-- ملاحظة: يجب استبدال الرابط برابط خريطة المطعم الفعلية من Google Maps -->
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3453.663339304193!2d31.23344931511516!3d30.04648598188151!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x145840c6a2873c33%3A0x8382d60f584e0c8b!2sTahrir%20Square!5e0!3m2!1sen!2seg!4v1665490000000!5m2!1sen!2seg" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer>
        <div class="container">
            <div class="social-links">
                <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                <a href="#" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
            </div>
            <p>&copy; 2024 بيت الأسماك. جميع الحقوق محفوظة.</p>
        </div>
    </footer>

    <script>
        // JavaScript for Mobile Menu
        const hamburger = document.querySelector('.hamburger');
        const navLinks = document.querySelector('.nav-links');

        hamburger.addEventListener('click', () => {
            navLinks.classList.toggle('active');
        });

        // JavaScript for Menu Tabs
        const tabs = document.querySelectorAll('.menu-tab');
        const contents = document.querySelectorAll('.menu-content');

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                // Remove active class from all tabs and contents
                tabs.forEach(item => item.classList.remove('active'));
                contents.forEach(item => item.classList.remove('active'));

                // Add active class to clicked tab and corresponding content
                tab.classList.add('active');
                document.getElementById(tab.dataset.target).classList.add('active');
            });
        });
    </script>
</body>
</html>